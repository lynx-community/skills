{
  "name": "@lynx-js/trace-processor",
  "description": "A WebAssembly build of the Perfetto Trace Processor providing a JavaScript API for querying Perfetto traces",
  "version": "0.0.1",
  "type": "module",
  "bin": {
    "trace-processor": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli.js",
      "types": "./dist/cli.d.ts"
    },
    "./vendor/perfetto/trace_processor.wasm": {
      "default": "./vendor/perfetto/trace_processor.wasm"
    }
  },
  "files": [
    "vendor",
    "dist"
  ],
  "scripts": {
    "prepare": "node scripts/prepare.js",
    "build": "tsc --build"
  },
  "devDependencies": {
    "@types/node": "^20",
    "esbuild": "^0.27.2",
    "tar": "^7.5.7"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "immer": "^10.1.1"
  }
}
