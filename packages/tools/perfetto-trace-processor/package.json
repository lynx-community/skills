{
  "name": "@lynx-js/trace-processor",
  "version": "0.0.1",
  "description": "A WebAssembly build of the Perfetto Trace Processor providing a JavaScript API for querying Perfetto traces",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli.js",
      "types": "./dist/cli.d.ts"
    },
    "./vendor/perfetto/trace_processor.wasm": {
      "default": "./vendor/perfetto/trace_processor.wasm"
    }
  },
  "bin": {
    "trace-processor": "./bin/trace-processor.js"
  },
  "files": [
    "vendor",
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "prepare": "node scripts/prepare.js",
    "test": "pnpm run build && node ./test/smoke.mjs"
  },
  "dependencies": {
    "@lynx-js/benchx-cli": "workspace:*",
    "commander": "^14.0.3",
    "immer": "^10.1.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "esbuild": "^0.27.2",
    "tar": "^7.5.7",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  }
}
